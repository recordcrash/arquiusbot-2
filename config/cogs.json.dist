{
    "status": {
        "status": [ // will loop over these
            "A beautiful stallion",
            "Command me, I order it",
            "Let's e%tol the virtues of horses"
        ],
        "status_interval": 60,
        "push_url": "https://example.com/push", // url to push heartbeat to
        "push_interval": 60,
    },
    "daily_counter": {  // user pung by daily counter
        "ping_user_id": 0
    },
    "linky": {  // user with stored and retrieved messages
        "user_id": 0
    },
    "log_manager": {
        "pastebin_token": "token"
    },
    "color_role_manager": {
        "channel_id": 4, // channel, message, emoji to listen for
        "color_role_messages": {
            "0": {
                // emoji to role id or name
                "1": "ghostyTrickster",
                "2": 533523553,

            },
            "1": {
                "3": "scratch",
                "4": "vantas",
            }
        }
    },
    "events": {
        "autoreact_channel_ids": [1] // autoreacts with a heart
    },
    "misc": {
        "latex_channel_ids": [1, 2, 3] // latex can only be used in these channels
    },
    "reddit_watcher": { // reposts high-scoring subreddit posts to a channel
        "subreddit": "homestuck",
        "channel_id": 0, // destination Discord channel id
        "min_score": 50, // only repost once the post crosses this score
        "interval_minutes": 10, // poll cadence (stay well under 10 req/min)
        "fetch_limit": 25, // capped at 100 by Reddit
        "user_agent": "arquiusbot/1.0 reddit-watcher",
        // OAuth2 app credentials from a "script" app at
        // https://www.reddit.com/prefs/apps — required from cloud/datacenter
        // hosts (DigitalOcean, AWS) since Reddit blocks anonymous requests
        // from those IP ranges. We use the client_credentials grant
        // (app-only OAuth), so no user account is involved. Leave blank
        // for local dev on a residential IP.
        "client_id": "",
        "client_secret": ""
    },
    "drewbot": {
        "openai_api_key": "sk-key",
        "patron_role_ids": [1], // role ids that can use the bot
        "drewbot_model_choices": [ // first will be chosen by default
          {
            "name": "Model name",
            "description": "Model description.",
            "id": "id-on-chatgpt"
          }
        ],
        "base_temperature": 0.85,
        "censored_words": ["pillweef"],
        "censor_character": "*",
        "system_prompt": "You are...",
        "username": "user",
        "username_full": "User"
    }
}
